# Carbon ERP/MES 生产环境配置
# 复制此文件为 .env 并填写实际值

# ============================================
# 基础配置
# ============================================

NODE_ENV=production

# Carbon 版本
CARBON_EDITION=community  # community | cloud | enterprise

# 会话密钥（必须修改，使用强随机字符串）
SESSION_SECRET=change-this-to-a-random-string-at-least-32-characters-long

# 默认语言
DEFAULT_LANGUAGE=zh  # zh | en | es | fr | de

# 认证方式
AUTH_PROVIDERS=email,google,passkey  # email | google | azure | passkey

# 速率限制（每小时登录尝试次数）
RATE_LIMIT=5

# ============================================
# 超级管理员账号（生产环境必须使用强密码）
# ============================================

SUPER_ADMIN_EMAIL=admin@yourcompany.com
SUPER_ADMIN_PASSWORD=ChangeThisToAVeryStrongPassword123!@#

# ============================================
# Supabase 配置（自托管）
# ============================================

# Supabase URL（使用你的域名）
SUPABASE_URL=https://api.yourcompany.com

# Supabase 密钥（从 Supabase .env 文件复制）
SUPABASE_ANON_KEY=your-anon-key-from-supabase-env
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-env

# 数据库连接（内网连接）
SUPABASE_DB_URL=postgresql://postgres:your-db-password@localhost:5432/postgres

# ============================================
# Redis 配置
# ============================================

REDIS_URL=redis://localhost:6379

# ============================================
# 应用端口（PM2 配置）
# ============================================

PORT_ERP=4000
PORT_MES=4001

# ============================================
# OAuth 配置（可选）
# ============================================

# Google OAuth
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Azure OAuth
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=your-azure-client-id
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_SECRET=your-azure-client-secret

# ============================================
# 邮件配置（可选）
# ============================================

# Resend API（用于发送邮件）
RESEND_API_KEY=re_your-resend-api-key
RESEND_DOMAIN=yourcompany.com

# 或者使用 SMTP
# SMTP_HOST=smtp.yourcompany.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourcompany.com
# SMTP_PASS=your-smtp-password

# ============================================
# Stripe 配置（可选，仅 Cloud 版本）
# ============================================

# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================
# 监控配置（可选）
# ============================================

# Posthog（用户行为分析）
# POSTHOG_API_HOST=https://us.posthog.com
# POSTHOG_PROJECT_PUBLIC_KEY=your-posthog-key

# ============================================
# AI 配置（可选）
# ============================================

# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# OPENAI_API_KEY=sk-proj-your-openai-key

# ============================================
# 其他配置
# ============================================

# Google Places API（地址自动完成）
# GOOGLE_PLACES_API_KEY=your-google-places-key

# Cloudflare Turnstile（验证码）
# CLOUDFLARE_TURNSTILE_SITE_KEY=your-site-key
# CLOUDFLARE_TURNSTILE_SECRET_KEY=your-secret-key

# Slack 通知
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ============================================
# 安全提示
# ============================================

# 1. 所有密钥必须使用强随机字符串
# 2. 生产环境不要使用默认密码
# 3. 定期轮换密钥
# 4. 不要将此文件提交到 Git
# 5. 使用环境变量管理工具（如 Vault）存储敏感信息
