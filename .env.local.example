# ============================================
# Carbon 本地开发环境配置
# ============================================
# 
# 复制此文件为 .env.local 并根据需要修改
# .env.local 会覆盖 .env 中的配置
#
# ============================================

# ============================================
# 性能优化选项
# ============================================

# 跳过数据库迁移检查 (如果 schema 没有变化)
# 可节省 5-15 秒启动时间
# CARBON_SKIP_MIGRATE=1

# 使用 localhost 而不是 portless .dev 域名
# 可节省 2-5 秒启动时间
# CARBON_PORTLESS=0

# 减少日志输出
# LOG_LEVEL=error

# ============================================
# 开发环境配置
# ============================================

# 开发服务器端口 (默认由 crbn 自动分配)
# PORT_ERP=4000
# PORT_MES=4001
# PORT_API=54321

# ============================================
# 数据库配置
# ============================================

# 如果需要连接到远程数据库
# SUPABASE_DB_URL=postgresql://postgres:password@localhost:5432/postgres

# ============================================
# 其他配置
# ============================================

# 启用调试模式
# DEBUG=true

# 禁用某些功能
# DISABLE_TELEMETRY=true
